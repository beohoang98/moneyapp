PORT=8080
DB_PATH=./moneyapp.db
JWT_SECRET=change-me

# Storage backend: "local" (filesystem) or "s3" (S3-compatible, e.g. MinIO)
# Default is "local" — no external services needed for local dev.
STORAGE_TYPE=local

# Local storage settings (used when STORAGE_TYPE=local)
LOCAL_STORAGE_PATH=./data/storage

# S3/MinIO settings (used when STORAGE_TYPE=s3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=moneyapp
MINIO_USE_SSL=false

BCRYPT_COST=12
TOKEN_EXPIRY_HOURS=24
CURRENCY=VND
